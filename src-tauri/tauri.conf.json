{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "NutriPolo",
    "version": "1.7.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": false,
        "save": true,
        "open": true
      },
      "fs": {
        "all": true,
        "scope": [
          "$APP/**",
          "$HOME/**",
          "$DOCUMENT/**",
          "$DESKTOP/**",
          "$DOWNLOAD/**"
        ]
      },
      "path": {
        "all": true
      },
      "process": {
        "all": false,
        "relaunch": true
      },
      "shell": {
        "all": false,
        "open": true
      },
      "http": {
        "all": false,
        "scope": [
          "https://oauth2.googleapis.com/**",
          "https://www.googleapis.com/**",
          "https://accounts.google.com/**"
        ]
      }
    },
    "bundle": {
      "active": true,
      "category": "Medical",
      "copyright": "© 2026 Javier Polo García",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.nutripolo.app",
      "longDescription": "Aplicación de escritorio para gestionar la consulta nutricional. Gestión de clientes, consultas, planes nutricionales y facturación.",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "Gestión de consulta nutricional",
      "targets": ["msi", "updater"],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "wix": null
      }
    },
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://oauth2.googleapis.com https://www.googleapis.com https://accounts.google.com https://github.com https://*.github.com https://objects.githubusercontent.com"
    },
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1N0MwQjc4RTJFNEE5RDIKUldUU3FlVGllQXQ4RmVVdnNtWHdsYzFoRHQzK1hRTzVvcUZnUWdrcy84M0RQcTNEL3B0RkRTYkMK",
      "endpoints": [
        "https://github.com/javipolog/NutriPolo/releases/latest/download/latest.json"
      ]
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "NutriPolo",
        "width": 1280,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true
      }
    ]
  }
}
