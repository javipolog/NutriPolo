{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Contabilidad Autónomo",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": false,
        "save": true,
        "open": true
      },
      "fs": {
        "all": true,
        "scope": [
          "$APP/*",
          "$DOCUMENT/*",
          "$DESKTOP/*",
          "$DOWNLOAD/*"
        ]
      },
      "path": {
        "all": true
      },
      "shell": {
        "all": false,
        "open": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": [
          "https://api.notion.com/*"
        ]
      }
    },
    "bundle": {
      "active": true,
      "category": "Finance",
      "copyright": "© 2026 Javier Polo García",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.javipolo.contabilidad",
      "longDescription": "Aplicación de escritorio para gestionar la contabilidad de autónomos. Incluye facturación, gastos, clientes y cálculo de impuestos trimestrales.",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "Contabilidad para autónomos",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "wix": null
      }
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.notion.com; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "Contabilidad Autónomo",
        "width": 1280,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true
      }
    ]
  }
}